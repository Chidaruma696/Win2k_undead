# Keep shell scripts LF so they run on Linux regardless of where they were cloned
* text=auto eol=lf
*.sh    text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.xml   text eol=lf

# Binary assets (never normalize/convert)
*.png   binary
*.jpg   binary
*.gif   binary
*.xpm   binary
*.svg   binary
*.ttf   binary
*.TTF   binary
*.ttc   binary
*.TTC   binary
*.otf   binary
*.wav   binary
*.WAV   binary
*.gz    binary
*.bz2   binary
*.so    binary
*.scr   binary
*.pdf   binary
*.ico   binary
